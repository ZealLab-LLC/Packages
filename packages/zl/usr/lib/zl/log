# Strict Mode
set -euo pipefail

FOLLOW=""
if [[ $# -gt 0 ]]; then
    if [[ "$1" == "-f" || "$1" == "--follow" ]]; then
        FOLLOW="-f"
    fi
fi

# We use grep with --line-buffered to ensure real-time stream output when following logs.
# We search for terms like vulkan, drm, pipewire, wayland, x11, session, error, fail.
if [[ -n "$FOLLOW" ]]; then
    journalctl -b 0 -f | grep --line-buffered -Ei "vulkan|drm|pipewire|wayland|x11|session|error|fail"
else
    journalctl -b 0 -e -q | grep -Ei "vulkan|drm|pipewire|wayland|x11|session|error|fail" | tail -n 50
fi
