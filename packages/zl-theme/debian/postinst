#!/bin/sh
set -e

lockscreen=/usr/share/plasma/shells/org.kde.plasma.desktop/contents/lockscreen/LockScreenUi.qml
overlay='file:///usr/share/zeallab/lockscreen/BrandOverlay.qml'

case "$1" in
    configure)
        if [ -f "$lockscreen" ] && [ -f /usr/share/zeallab/lockscreen/BrandOverlay.qml ]; then
            python3 -c '
path = "'"$lockscreen"'"
overlay = "'"$overlay"'"
with open(path, "r") as f:
    content = f.read()

lines = content.splitlines()
new_lines = []
skip = False
for line in lines:
    if "id: zealLabBrandOverlay" in line:
        if new_lines and "Loader {" in new_lines[-1]:
            new_lines.pop()
        skip = True
        continue
    if skip:
        if line.strip() == "}":
            skip = False
        continue
    new_lines.append(line)

content = "\n".join(new_lines) + "\n"

# Remove any extra unclosed dangling Loader { before DropShadow
content = content.replace("Loader {\n\n        DropShadow", "DropShadow")

target = "DropShadow {"
if target in content:
    insertion = """        Loader {
            id: zealLabBrandOverlay
            anchors.fill: parent
            source: "%s"
            onLoaded: item.panelVisible = Qt.binding(() => lockScreenRoot.uiVisible)
        }\n        """ % overlay
    content = content.replace(target, insertion + target, 1)

content = content.replace("visible: !config.alwaysShowClock", "visible: false")

with open(path, "w") as f:
    f.write(content)
'
        fi
        ;;
esac

#DEBHELPER#
exit 0
